# WhatsApp Cloud API Configuration
# Get these from Meta for Developers: https://developers.facebook.com/
WHATSAPP_VERIFY_TOKEN=your_verify_token_here
WHATSAPP_TOKEN=your_access_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here

# OpenAI API Configuration
# Get your API key from: https://platform.openai.com/
MODEL_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key_here
MODEL_NAME=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-large

# SerpAPI Configuration (for enhanced web search)
# Get your API key from: https://serpapi.com/
SERPAPI_KEY=your_serpapi_key_here

# Storage Configuration
REDIS_URL=redis://redis:6379/0
RAG_VECTOR_DIR=./vectorstore
TRAINING_ROOT=./training-files/general-hazard-awareness

# Deployment Configuration
DEPLOYMENT_TIMESTAMP=20250910170000

# ── Registration & Early Warning Alert Features ───────────────────────────

# SQLite database path for subscriber registrations
REGISTRATIONS_DB=./data/registrations.db

# Google Form URL (share this link in the WhatsApp bot's first message)
# Create a form at https://forms.google.com and paste the shareable link here
REGISTRATION_FORM_URL=https://forms.gle/YOUR_FORM_ID_HERE

# Google Sheets integration (for syncing form responses)
# 1. Create a Service Account in Google Cloud Console
# 2. Download the JSON key → save as credentials.json in project root
# 3. Share the Form's response Google Sheet with the service account email
# 4. Paste the Spreadsheet ID from the Sheet URL below
GOOGLE_SHEETS_CREDENTIALS_FILE=./credentials.json
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here

# GitHub Pages early warning data URL
# After pushing early-warning-site/ to GitHub and enabling Pages, set:
# EARLY_WARNING_DATA_URL=https://<username>.github.io/<repo>/data.json
EARLY_WARNING_DATA_URL=https://your-username.github.io/your-repo/data.json

# Scheduler intervals (minutes)
SHEETS_SYNC_INTERVAL_MINUTES=30
ALERT_CHECK_INTERVAL_MINUTES=60

# Admin endpoint protection (optional – leave empty to disable in dev)
ADMIN_SECRET=your_admin_secret_here
